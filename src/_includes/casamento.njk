---
layout: base.njk
---
<div class="modal-article article-wrap">
  <a href="/#casamentos" class="article-back">← Voltar aos casamentos</a>
  {% if hero %}<img class="article-hero-img wedding-hero" src="{{ hero }}" alt="{{ title }}">{% endif %}
  <div class="modal-body">
    <div class="modal-cat">{{ category }}</div>
    <div class="modal-title wedding-name">{{ title | safe }}</div>
    <div class="modal-meta">{{ meta | safe }}</div>
    <div class="modal-text">
      {{ content | safe }}
    </div>
    {% if gallery_images %}
    <div class="wedding-modal-gallery">
      {% for img in gallery_images %}
      <img class="{{ 'span-full' if loop.index0 % 3 == 0 else 'port' }}" src="{{ img.image }}" alt="{{ title }}">
      {% endfor %}
    </div>
    {% endif %}
    <div class="article-cta">
      <div class="article-cta-title">Quer realizar seu casamento no Kauai?</div>
      <a href="https://wa.me/5562982420120?text=Ol%C3%A1%2C%20Kauai%21%20Vim%20pelo%20blog%20e%20quero%20saber%20mais%20sobre%20o%20espa%C3%A7o%20e%20o%20buffet." target="_blank" class="btn-primary">Falar no WhatsApp</a>
    </div>
  </div>
</div>
