---
layout: base.njk
---
<div class="modal-article article-wrap">
  <a href="{{ '/' | url }}" class="article-back">← Voltar ao blog</a>
  {% if hero %}<img class="article-hero-img" src="{{ hero | url }}" alt="{{ title }}">{% endif %}
  <div class="modal-body">
    <div class="modal-cat">{{ category }}</div>
    <div class="modal-title">{{ title }}</div>
    <div class="modal-meta">{{ meta | safe }}</div>
    <div class="modal-text">{{ content | safe }}</div>
    <div class="article-cta">
      <div class="article-cta-title">Gostou? Conheça o Kauai Eventos.</div>
      <p class="article-cta-sub">Espaço + Buffet exclusivo em Goiânia.</p>
      <a href="https://wa.me/5562982420120?text=Ol%C3%A1%2C%20Kauai%21%20Vim%20pelo%20blog%20e%20quero%20saber%20mais%20sobre%20o%20espa%C3%A7o%20e%20o%20buffet." target="_blank" class="btn-primary">Falar no WhatsApp</a>
    </div>
  </div>
</div>
