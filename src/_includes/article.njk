---
layout: base.njk
---
<div class="modal-article" style="position:static;max-width:860px;margin:110px auto 60px;padding:0 48px;">
  <a href="/" style="display:inline-flex;align-items:center;gap:6px;font-size:11px;letter-spacing:2px;text-transform:uppercase;color:#6a6a50;margin-bottom:24px;">← Voltar ao blog</a>
  {% if hero %}<img class="modal-hero-img" src="{{ hero }}" alt="{{ title }}" style="width:100%;border-radius:12px;margin-bottom:32px;">{% endif %}
  <div class="modal-body">
    <div class="modal-cat">{{ category }}</div>
    <div class="modal-title">{{ title }}</div>
    <div class="modal-meta">{{ meta }}</div>
    <div class="modal-text">{{ content | safe }}</div>
    <div style="margin-top:40px;padding-top:28px;border-top:1px solid #ece6dc;text-align:center;">
      <div style="font-family:'Cormorant Garamond',serif;font-size:22px;color:#1a1a12;margin-bottom:8px;">Gostou? Conheça o Kauai Eventos.</div>
      <p style="font-size:12px;color:#8a8a6a;margin-bottom:20px;">Espaço + Buffet exclusivo em Goiânia.</p>
      <a href="https://wa.me/5562982420120?text=Ol%C3%A1%2C%20Kauai%21%20Vim%20pelo%20blog%20e%20quero%20saber%20mais%20sobre%20o%20espa%C3%A7o%20e%20o%20buffet." target="_blank" class="btn-primary">Falar no WhatsApp</a>
    </div>
  </div>
</div>
