<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{{ seoTitle or title }} · Blog Kauai Eventos</title>
<meta name="description" content="{{ seoDescription or 'Blog do Kauai Eventos — casamentos reais em Goiânia, dicas de planejamento, buffet e inspirações.' }}">
<link rel="canonical" href="https://kauaieventos.com/blog{{ page.url }}">
<meta property="og:type" content="article">
<meta property="og:title" content="{{ seoTitle or title }}">
<meta property="og:description" content="{{ seoDescription or '' }}">
{% if hero %}<meta property="og:image" content="https://kauaieventos.com/blog{{ hero }}">{% endif %}
<link rel="stylesheet" href="/style.css">
</head>
<body>
<nav>
  <a href="/" class="nav-logo-link"><b>KAUAI</b> · Blog</a>
  <div class="nav-links">
    <a href="/#artigos" class="nav-link">Artigos</a>
    <a href="/#casamentos" class="nav-link">Casamentos Reais</a>
    <a href="https://wa.me/5562982420120?text=Ol%C3%A1%2C%20Kauai%21%20Vim%20pelo%20blog%20e%20quero%20saber%20mais%20sobre%20o%20espa%C3%A7o%20e%20o%20buffet." target="_blank" class="nav-cta">Falar no WhatsApp</a>
  </div>
</nav>

{{ content | safe }}

<footer style="padding:60px 48px;text-align:center;border-top:1px solid #ece6dc;margin-top:60px;">
  <div style="font-family:'Cormorant Garamond',serif;font-size:22px;margin-bottom:16px;">KAUAI Eventos</div>
  <div style="display:flex;gap:20px;justify-content:center;flex-wrap:wrap;font-size:12px;color:#8a8a6a;">
    <a href="https://kauaieventos.com">Site</a>
    <a href="https://instagram.com/kauaieventos" target="_blank">Instagram</a>
    <a href="https://www.tiktok.com/@kauai.eventos" target="_blank">TikTok</a>
    <a href="https://wa.me/5562982420120" target="_blank">WhatsApp</a>
  </div>
  <div style="margin-top:20px;font-size:11px;color:#b0a880;">© {{ year }} Kauai Eventos · Goiânia, GO · Blog de casamentos em Goiânia</div>
</footer>
</body>
</html>
