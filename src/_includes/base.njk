<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{{ seoTitle or title }} · Blog Kauai Eventos</title>
<meta name="description" content="{{ seoDescription or 'Blog do Kauai Eventos — casamentos reais em Goiânia, dicas de planejamento, buffet e inspirações.' }}">
<link rel="canonical" href="https://kauaieventos.com{{ page.url | url }}">
<meta property="og:type" content="article">
<meta property="og:title" content="{{ seoTitle or title }}">
<meta property="og:description" content="{{ seoDescription or '' }}">
{% if hero %}<meta property="og:image" content="https://kauaieventos.com{{ hero | url }}">{% endif %}
<link rel="stylesheet" href="{{ '/style.css' | url }}">
</head>
<body>
<nav>
  <a href="{{ '/' | url }}" class="nav-logo-link"><img class="nav-logo" src="{{ '/images/nav-logo.png' | url }}" alt="Kauai Eventos"> <span>Blog</span></a>
  <div class="nav-links">
    <a href="{{ '/' | url }}#artigos" class="nav-link">Artigos</a>
    <a href="{{ '/' | url }}#casamentos" class="nav-link">Casamentos Reais</a>
    <a href="{{ '/contribua/' | url }}" class="nav-link">Conte sua história</a>
    <a href="https://wa.me/5562982420120?text=Ol%C3%A1%2C%20Kauai%21%20Vim%20pelo%20blog%20e%20quero%20saber%20mais%20sobre%20o%20espa%C3%A7o%20e%20o%20buffet." target="_blank" class="nav-cta">Falar no WhatsApp</a>
  </div>
</nav>

{{ content | safe }}

<footer class="site-footer">
  <div class="site-footer-brand">KAUAI Eventos</div>
  <div class="site-footer-links">
    <a href="https://kauaieventos.com">Site</a>
    <a href="https://instagram.com/kauaieventos" target="_blank">Instagram</a>
    <a href="https://www.tiktok.com/@kauai.eventos" target="_blank">TikTok</a>
    <a href="https://wa.me/5562982420120" target="_blank">WhatsApp</a>
  </div>
  <div class="site-footer-copy">© {{ year }} Kauai Eventos · Goiânia, GO · Blog de casamentos em Goiânia</div>
</footer>
</body>
</html>
